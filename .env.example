# Docker Compose 项目名，固定后可避免中文目录名影响容器/网络名称
COMPOSE_PROJECT_NAME=wjehomesvc

# PostgreSQL
POSTGRES_USER=wjehomesvc
POSTGRES_PASSWORD=wjehomesvc_password
POSTGRES_DB=wjehomesvc
DATABASE_URL=postgresql://wjehomesvc:wjehomesvc_password@db:5432/wjehomesvc?schema=public

# Backend
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
BACKEND_PORT=38304

# Frontend
FRONTEND_PORT=38204
VITE_API_BASE_URL=/api
VITE_WS_URL=ws://localhost:38304/notifications
